# ============================================================================
# Crypto Market Screener — environment configuration
# Copy to .env and adjust as needed. Defaults are safe for mock-mode evaluation.
# ============================================================================

# ---- Operating mode ---------------------------------------------------------
# Three modes are supported (see README "How to switch live"):
#
#   1) Live public mode (default — recommended for production):
#        USE_MOCK_DATA=false
#        ENABLE_PUBLIC_API_ADAPTERS=true
#        ENABLED_EXCHANGES=binance,bybit,okx,coinbase,kraken
#
#   2) Mock-only mode (tests/dev only):
#        USE_MOCK_DATA=true
#        ENABLE_PUBLIC_API_ADAPTERS=false
#
#   3) Hybrid mode (both — mock and public coexist via composite store key):
#        USE_MOCK_DATA=true
#        ENABLE_PUBLIC_API_ADAPTERS=true
#        ENABLED_EXCHANGES=binance,bybit,okx,coinbase,kraken
#
USE_MOCK_DATA=false
ENABLE_PUBLIC_API_ADAPTERS=true
ENABLED_EXCHANGES=binance,bybit,okx,coinbase,kraken
# Alias of USE_MOCK_DATA for clarity in tests/dev.
ENABLE_TEST_FIXTURES=false

LOG_LEVEL=info

# ---- Mock adapter -----------------------------------------------------------
MOCK_MARKET_COUNT=80          # 50..100
MOCK_UPDATE_INTERVAL_MS=750
MOCK_SEED=42

# ---- Job cadence ------------------------------------------------------------
SCREENER_INTERVAL_MS=1000
ALERT_INTERVAL_MS=2000        # alerts evaluator runs every 2s

# ---- WebSocket --------------------------------------------------------------
WS_BATCH_INTERVAL_MS=750      # validated to be 500..1000
WS_BATCH_MAX_ENTRIES=500

# ---- Persistence ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/screener
REDIS_URL=redis://redis:6379

# ---- HTTP -------------------------------------------------------------------
API_PORT=4000
WEB_PORT=3000
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# ---- Detector defaults ------------------------------------------------------
VOLUME_SPIKE_REL_VOL_THRESHOLD=3.0
VOLUME_SPIKE_TIMEFRAME=5m
PRICE_PUMP_PCT=2.0
PRICE_PUMP_TIMEFRAME=5m
PRICE_DUMP_PCT=-2.0
PRICE_DUMP_TIMEFRAME=5m
VOLATILITY_MULTIPLIER=2.0
VOLATILITY_TIMEFRAME=5m
SPREAD_PCT_THRESHOLD=0.15
OB_IMBALANCE_DEPTH=20
OB_IMBALANCE_RATIO=0.65
OI_SPIKE_PCT=5.0
OI_SPIKE_TIMEFRAME=15m
FUNDING_ABS_THRESHOLD=0.03
BREAKOUT_LOOKBACK=20
BREAKOUT_TIMEFRAME=5m
HOT_MARKET_SCORE_THRESHOLD=81

# ---- Frontend ---------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# ---- No-subscription data policy --------------------------------------------
# Paid SaaS providers are not constructed at all.
DISABLE_PAID_PROVIDERS=true
# none = market cap / metadata is unavailable in this MVP build.
MARKET_METADATA_PROVIDER=none
# Hard timeout for each upstream call.
EXTERNAL_API_TIMEOUT_MS=5000
# TTL (seconds) for cached responses from public APIs.
EXTERNAL_API_CACHE_TTL_SECONDS=30

# ---- Live polling for public adapters (REST → MarketDataStore) --------------
# Interval between polling cycles. Set 0 to disable.
LIVE_POLLING_INTERVAL_MS=60000
# Max symbols polled per adapter per cycle (rate-limit aware default).
LIVE_POLLING_SYMBOL_LIMIT=15

# ---- Liquidity Heatmap memory limits ----------------------------------------
# Hard cap (in hours) on the heatmap lookback when the user picks "Max" in
# the UI. Protects the browser from rendering multi-day matrices.
MAX_HEATMAP_LOOKBACK_HOURS=4
