{
  "name": "@screener/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push --accept-data-loss",
    "postinstall": "prisma generate || echo \"prisma generate skipped\""
  },
  "dependencies": {
    "@fastify/cors": "10.0.1",
    "@fastify/rate-limit": "10.1.1",
    "@fastify/websocket": "11.0.1",
    "@prisma/client": "5.20.0",
    "@screener/engine": "workspace:*",
    "@screener/shared": "workspace:*",
    "fastify": "5.0.0",
    "ioredis": "5.4.1",
    "pino": "9.4.0",
    "pino-pretty": "11.2.2",
    "ws": "8.18.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.16.5",
    "@types/ws": "8.5.12",
    "fast-check": "^4.8.0",
    "prisma": "5.20.0",
    "tsx": "4.19.1",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
